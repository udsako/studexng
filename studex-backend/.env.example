# Django Settings
SECRET_KEY=your-secret-key-here-use-django-generate-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (For production, use PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/studex_db

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Paystack API Keys (Get from https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Firebase Service Account
# Place firebase_service_account.json in the parent directory

# Email Configuration (Optional - for production)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# University Email Domains (Optional - comma-separated)
# ALLOWED_UNIVERSITY_DOMAINS=pau.edu.ng,unilag.edu.ng

# Blockchain (Optional - for future blockchain integration)
# POLYGON_PRIVATE_KEY=your_polygon_private_key_here
# POLYGON_RPC_URL=https://polygon-rpc.com
